#include <iostream>
#include <vector>
#include <unordered_map>
struct road{
    int s;
    std::vector<int> r;
};
void fillPoints(std::unordered_map<int, road> &points){
    int point;
    int s;
    int newPoint;
    std::cout << "Please enter the first point: ";
    std::cin >> point;
    points[point].s = 0;
    points[point].r.push_back(point);
    while(true){
        std::cout << std::endl;
        std::cout << "If you wanna stop input, please enter '-1'" << std::endl;
        std::cout << std::endl;
        std::cout << "Please enter new point: ";
        std::cin >> point;
        if(point < 0 or point == -1) return;
        std::cout << "Please enter the s: ";
        std::cin >> s;
        if(s < 0) return;
        points[point].s = s;
        std::cout << "Please enter from which point do you wanna go: ";
        std::cin >> newPoint;
        if(newPoint < 0) return;
        if(points.find(newPoint) != points.end()){
            s += points[newPoint].s; 
            if(points[newPoint].r.back() != newPoint){
            points[newPoint].r.push_back(newPoint);}

        }
        points[point].s = s;
        points[point].r.insert(points[point].r.end(), points[newPoint].r.begin(), points[newPoint].r.end());
    }
}
int main(){
  std::unordered_map<int, road> points;
  fillPoints(points);
  int max = -1;
  int min = 100000;
  int resultPointMax;
  int resultPointMin;
  for(auto point : points){
    if(point.second.r.back() != point.first){
        if(point.second.s > max){
        max = point.second.s;
        resultPointMax = point.first;
    }
        if(point.second.s < min){
        min = point.second.s;
        resultPointMin = point.first;
    }
    }
    else{
        continue;
    }
  }

  std::vector<int> resultMax;
  std::vector<int> resultMin;
  if(max != -1){
    resultMax = points[resultPointMax].r;
  }
  resultMax.push_back(resultPointMax);
  if(min != 100000){
    resultMin = points[resultPointMin].r;
  }
  resultMin.push_back(resultPointMin);
  std::cout << "The longest way is: ";
  for(int i = 0; i < resultMax.size(); i++){
    std::cout << resultMax[i] << " ";
  }
  std::cout << std::endl;
  std::cout << "The shotest way is: ";
  for(int i = 0; i < resultMin.size(); i++){
    std::cout << resultMin[i] << " ";
  }

}
